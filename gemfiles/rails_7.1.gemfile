# frozen_string_literal: true

# Rails 7.1 - Latest 7.1.x
# Ruby: >= 3.2

source 'https://rubygems.org'

gem 'rails', '~> 7.1.4'
gem 'sqlite3', '~> 1.6'

# Pin nokogiri to avoid conflicts
gem 'nokogiri', '~> 1.16.0'

# Pin minitest - Rails 7.1 works with minitest 5.x
gem 'minitest', '~> 5.27'

# Test framework
gem 'rspec-rails', '~> 6.1'

group :development, :test do
  gem 'debug'
end
